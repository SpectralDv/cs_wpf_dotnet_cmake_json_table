<Window x:Class="wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:wpf"
        xmlns:vm="clr-namespace:wpf.ViewModel" 
        mc:Ignorable="d"
        Title="XMLChannels" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen" FontSize="16">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid x:Name="MainGrid" Background="#1d2021">


    <Grid.RowDefinitions>
        <RowDefinition Height="22" />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition />
        <ColumnDefinition />
    </Grid.ColumnDefinitions>


    <DockPanel DockPanel.Dock="Top" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
        <Menu Background="#292d2e">
            <MenuItem Header="{Binding menuSettings}" Background="#292d2e" Foreground="White" Margin="10 2 0 0">
                <MenuItem Header="{Binding bChangeLanguage}" Background="#292d2e" Foreground="White"
                Command="{Binding ClickChangeLanguage}"/>
            </MenuItem>
        </Menu>
    </DockPanel >

    <Button Grid.Row="4" Grid.Column="1"
        Height="40" Width="120"
        Command="{Binding ClickOpenDialog}">
        <TextBlock Text="{Binding bOpenDialog}"/>
    </Button>

    <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="1"
        Text="{Binding TextLog}"
        Foreground="White"
        FontSize="10"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"/>

    <!-- Text="Channels (select by double click)" -->
    <TextBlock Grid.Row="1" Grid.Column="0"
        Text="{Binding tlNameTable}"
        Foreground="White"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Center"/>

    <TextBlock Grid.Row="1" Grid.Column="1"
        Text="{Binding tlHandID}"
        Foreground="White"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Center"/>

    <TextBlock Grid.Row="1" Grid.Column="2"
        Text="{Binding tlData}"
        Foreground="White"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Center"/>

    <ListBox Grid.Row="2" Grid.Column="0" Grid.RowSpan="2"
        ItemsSource="{Binding ViewNameTable}"
        SelectedItem="{Binding SelectNameTable}"
        Foreground="White"
        Background="#292d2e">

        <b:Interaction.Triggers>
            <b:EventTrigger EventName="MouseDoubleClick">
                <b:InvokeCommandAction Command="{Binding OpenHandId}"/>
            </b:EventTrigger>
        </b:Interaction.Triggers>

        <ListBox.ItemTemplate>
            <DataTemplate>  
                <Grid>
                    <TextBlock Text="{Binding name}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

    <ListBox Grid.Row="2" Grid.Column="1" Grid.RowSpan="2"
        ItemsSource="{Binding ViewHandId}"
        SelectedItem="{Binding SelectHandId}"
        Foreground="White"
        Background="#292d2e">

        <b:Interaction.Triggers>
            <b:EventTrigger EventName="MouseDoubleClick">
                <b:InvokeCommandAction
                    Command="{Binding OpenData}"/>
            </b:EventTrigger>
        </b:Interaction.Triggers>

        <ListBox.ItemTemplate>
            <DataTemplate>  
                <Grid>
                    <TextBlock Text="{Binding name}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

    <ListBox Grid.Row="2" Grid.Column="2" Grid.RowSpan="2"
        ItemsSource="{Binding ViewData}"
        Foreground="White"
        Background="#292d2e">

        <ListBox.ItemTemplate>
            <DataTemplate>  
                <Grid>
                    <TextBlock Text="{Binding name}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>


    </Grid>
</Window>
